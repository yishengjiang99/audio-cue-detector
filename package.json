{
  "name": "audio-cue-detector",
  "version": "1.0.0",
  "description": "Browser-native advisory audio cue coach for Solo Shuffle",
  "private": true,
  "bin": {
    "audio-cue-coach": "./bin/audio-cue-coach.js"
  },
  "scripts": {
    "start": "node bin/audio-cue-coach.js",
    "serve": "node bin/audio-cue-coach.js",
    "test:e2e": "playwright test",
    "train:youtube": "node training/youtube-train.mjs training/sources.example.json",
    "train:youtube:py": "python3 training/youtube_train.py training/sources.example.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0"
  },
  "engines": {
    "node": ">=18"
  }
}